# Server
NODE_ENV=production
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/evoting?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRE=2h
JWT_COOKIE_EXPIRE=2

# Vote Encryption
VOTE_ENCRYPTION_KEY=your_256bit_hex_encryption_key_here_64chars

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.onrender.com

# Default seed password
DEFAULT_SEED_PASSWORD=CHCCIVote2025!

# Admin Email
ADMIN_EMAIL=admin@chcci.edu.ph

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Security tuning
BCRYPT_ROUNDS=12
# Increase to 14 for production if server can handle the load (~1s per hash at 14)
