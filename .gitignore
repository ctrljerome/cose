# ═══════════════════════════════════════════════
# SUFFRAGE — E-Voting System
# .gitignore
# ═══════════════════════════════════════════════

# ── ENVIRONMENT & SECRETS ───────────────────────
# NEVER commit these — they contain DB URIs,
# JWT secrets, encryption keys, email credentials
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
backend/.env
frontend/.env

# ── DEPENDENCIES ────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── BUILD OUTPUT ─────────────────────────────────
frontend/dist/
frontend/build/
backend/dist/
build/
dist/

# ── LOGS ─────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/logs/

# ── TEST COVERAGE ────────────────────────────────
coverage/
backend/coverage/
*.lcov
.nyc_output/

# ── OS FILES ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── EDITOR & IDE ─────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── VITE / FRONTEND TOOLING ───────────────────────
frontend/.vite/
frontend/node_modules/.vite/

# ── MISC ─────────────────────────────────────────
*.zip
*.tar.gz
*.pem
*.key
*.cert
*.p12
